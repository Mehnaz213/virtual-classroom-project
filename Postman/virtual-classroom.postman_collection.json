{
  "info": {
    "name": "AI Virtual Classroom",
    "_postman_id": "3f6c2a86-8d0d-4a5d-8b42-fake",
    "description": "Sample requests for the AI-powered virtual classroom API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"teacher@example.com\",\n    \"password\": \"teach123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login/json",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login",
            "json"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/class/1/dashboard",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "class",
            "1",
            "dashboard"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"topic\": \"Demo Session\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/class/create",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "class",
            "create"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Join Session (Student)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"code\": \"{{sessionCode}}\",\n    \"lock_mode\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/class/{{sessionId}}/join",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "class",
            "{{sessionId}}",
            "join"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Post Frame Event",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"session_id\": {{sessionId}},\n    \"attendance_id\": {{attendanceId}},\n    \"frame_b64\": \"<base64-frame>\",\n    \"tab_switch\": false,\n    \"multiple_faces\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/events/frame",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events",
            "frame"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Download Report",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/reports/{{sessionId}}?format=csv",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reports",
            "{{sessionId}}"
          ],
          "query": [
            {
              "key": "format",
              "value": "csv"
            }
          ]
        }
      },
      "response": []
    }
  ]
}

